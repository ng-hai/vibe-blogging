                    0
                  ],
                  "children": [
                    {
                      "type": "frame",
                      "id": "HP1Pj",
                      "name": "c1a",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 20,
                      "children": [
                        {
                          "type": "text",
                          "id": "vBDjh",
                          "name": "c1aP",
                          "fill": "$text",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Nhưng nếu bạn ngồi đủ lâu — không bấm điện thoại, không mở thêm tab, không cuộn xuống — trang trắng sẽ bắt đầu nói. Không to. Chỉ là một câu nhỏ. Một mảnh ý. Một từ mà sáng nay bạn đang cần.",
                          "lineHeight": 1.7,
                          "fontFamily": "$font-body",
                          "fontSize": 17,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "e9Iku",
