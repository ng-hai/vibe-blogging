                          "id": "5C0l2",
                          "name": "c1aP2",
                          "fill": "$text",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Tôi tin rằng buổi sáng có một loại im lặng riêng — loại im lặng không nặng nề, mà giống như đang nâng đỡ. Nó cho phép bạn nghĩ những điều không vội.",
                          "lineHeight": 1.7,
                          "fontFamily": "$font-body",
                          "fontSize": 17,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "8J118",
                      "name": "c1b",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 16,
                      "children": [
                        {
                          "type": "text",
                          "id": "6EXbG",
                          "name": "c1bP",
                          "fill": "$text",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Tôi không gọi đây là dự án. Một dự án có deadline, có KPI, có cảm giác tội lỗi khi bỏ lỡ một ngày. Một thói quen thì khác.",
                          "lineHeight": 1.7,
                          "fontFamily": "$font-body",
                          "fontSize": 17,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "GPdpB",
                          "name": "c1bP2",
                          "fill": "$text",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Thói quen như tưới cây — bạn chỉ cần đến đúng giờ, mở vòi, để nước chảy đủ. Không cần phải là cây cao. Không cần phải đẹp. Chỉ cần xanh.",
                          "lineHeight": 1.7,
                          "fontFamily": "$font-body",
                          "fontSize": 17,
