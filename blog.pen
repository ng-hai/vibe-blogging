                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "Tôi không gọi đây là dự án. Một dự án có deadline, có KPI, có cảm giác tội lỗi khi bỏ lỡ một ngày. Một thói quen thì khác.",
                          "lineHeight": 1.7,
                          "fontFamily": "$font-body",
