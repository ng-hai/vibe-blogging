                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 10,
                          "padding": [
                            16,
                            0
                          ],
                          "alignItems": "center",
                          "children": [
                            {
                              "type": "text",
                              "id": "Ymrrx",
                              "name": "pMk",
                              "fill": "$rose",
                              "content": "“",
                              "lineHeight": 0.7,
