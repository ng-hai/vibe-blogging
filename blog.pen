                              "fontFamily": "$font-heading",
                              "fontSize": 64,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "B3S5U",
                              "name": "pTx",
                              "fill": "$text",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Viết mỗi ngày không phải để giỏi hơn. Viết mỗi ngày để hiểu rõ hơn — về mình, về thời gian, về một dòng cà phê đang nguội.",
                              "lineHeight": 1.4,
                              "textAlign": "center",
                              "fontFamily": "$font-body",
