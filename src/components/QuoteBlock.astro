---
interface Props {
	label?: string;
	author?: string;
}

const { label = 'Featured Quote', author } = Astro.props;
---

<figure class="quote-block">
	<div class="inner">
		<svg
			class="icon"
			viewBox="0 0 24 24"
			width="24"
			height="24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
		>
			<path d="M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z" />
			<path d="M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2 1 1 0 0 1 1 1v1a2 2 0 0 1-2 2 1 1 0 0 0-1 1v2a1 1 0 0 0 1 1 6 6 0 0 0 6-6V5a2 2 0 0 0-2-2z" />
		</svg>
		{label && <p class="label">{label}</p>}
		<blockquote class="text"><slot /></blockquote>
		{author && <figcaption class="author">— {author}</figcaption>}
	</div>
</figure>

<style>
	.quote-block {
		margin: 1.5em 0;
		padding: 24px 24px 24px 20px;
		background-color: var(--color-overlay);
		border-radius: 12px;
	}
	.inner {
		display: flex;
		flex-direction: column;
		gap: 12px;
		padding-left: 16px;
		border-left: 4px solid var(--color-rose);
	}
	.icon {
		color: var(--color-rose);
		opacity: 0.6;
	}
	.label {
		margin: 0;
		font-family: var(--font-heading);
		font-size: 14px;
		font-weight: 600;
		letter-spacing: 0.5px;
		color: var(--color-text);
	}
	.text {
		margin: 0;
		padding: 0;
		border: 0;
		background: none;
		border-radius: 0;
		font-family: var(--font-body);
		font-size: 18px;
		line-height: 1.6;
		color: var(--color-text);
	}
	.text::before,
	.text::after {
		content: none;
	}
	.text :global(p) {
		margin: 0;
	}
	.text :global(p + p) {
		margin-top: 0.5em;
	}
	.author {
		margin: 0;
		font-family: var(--font-body);
		font-size: 14px;
		font-style: italic;
		color: var(--color-muted);
	}
</style>
