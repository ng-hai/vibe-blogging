---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	src: ImageMetadata;
	alt: string;
	caption?: string;
	width?: number;
}

const { src, alt, caption, width = 420 } = Astro.props;
---

<figure class="portrait" style={`--portrait-width: ${width}px`}>
	<Image src={src} alt={alt} widths={[320, 480, 640]} sizes={`${width}px`} />
	{caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
	.portrait {
		margin: 1.75em auto;
		max-width: var(--portrait-width);
		width: 100%;
	}
	.portrait img {
		display: block;
		width: 100%;
		aspect-ratio: 3 / 4;
		object-fit: cover;
		border-radius: 12px;
	}
	figcaption {
		margin-top: 0.75em;
		font-family: var(--font-body);
		font-size: 14px;
		font-style: italic;
		color: var(--color-muted);
		text-align: center;
		line-height: 1.4;
	}
</style>
